{
  "manifest_version": 3,
  "name": "Google Account Fixer",
  "version": "1.1",
  "permissions": ["declarativeNetRequest", "declarativeNetRequestFeedback", "storage"],
  "host_permissions": [
    "https://docs.google.com/*",
    "https://drive.google.com/*"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "background": {
    "service_worker": "background.js"
  }
}
